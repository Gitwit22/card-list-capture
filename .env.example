# Card Capture - Cloudflare Pages Environment Configuration

# API Backend
VITE_API_BASE_URL=https://api.example.com
VITE_API_TIMEOUT_MS=30000

# Auth Configuration
VITE_AUTH_ENABLED=true
VITE_JWT_SECRET=your_jwt_secret_here

# App Partition (for multi-tenant support)
VITE_APP_PARTITION=card-capture-app

# Core Service Endpoints
VITE_AUTH_CORE_URL=https://auth-service.example.com
VITE_STORAGE_CORE_URL=https://storage-service.example.com
VITE_AUDIT_CORE_URL=https://audit-service.example.com

# Feature Flags
VITE_ENABLE_AI_CLASSIFICATION=true
VITE_ENABLE_DOCUMENT_OCR=false
VITE_ENABLE_CARD_STORAGE=true

# Analytics & Monitoring
VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=

# App Configuration
VITE_APP_ENV=development
VITE_DEBUG_MODE=false

# Card Capture Specific
VITE_MAX_FILE_SIZE_MB=50
VITE_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,docx
